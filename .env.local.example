# ─────────────────────────────────────────────────────────────────────────────
# Visitor Intelligence (Workstream C) — STAGED, ships dark until cutover.
# Set these two vars on Vercel ONLY when Pierre approves turning tracking on.
# Both are no-ops while unset: the emitter/consent scripts don't render and the
# /collect rewrite + server-side join are skipped.
# ─────────────────────────────────────────────────────────────────────────────

# Master kill switch for the first-party visitor-intelligence emitter + consent
# prompt. Must be the literal string "true" to enable (public — exposed to the
# browser). Default off.
NEXT_PUBLIC_VI_ENABLED=false

# Origin of the first-party event collector (FastAPI service on linux-infer,
# fronted by a Cloudflare tunnel). The browser always POSTs same-origin /collect;
# next.config.mjs rewrites /collect -> ${COLLECTOR_ORIGIN}/collect server-side, and
# the intake routes POST the server-side submit join to ${COLLECTOR_ORIGIN}/collect.
# No trailing slash. Value filled at cutover from ~/visitor-intel/COLLECTOR_URL.txt
# (chosen by Workstream A). Example: https://collect.louislawgroup.com
COLLECTOR_ORIGIN=
