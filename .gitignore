*
!.env.local

# allow sitemaps in public
!public/
public/*
!public/images/

!public/images/**
!public/sitemap*.xml
!public/robots.txt

# allow dynamic sitemap route
!src/app/sitemap.xml/
!src/app/sitemap.xml/route.js

# allow config
!src/config/
!src/config/**

# allow helper libs
!src/lib/
!src/lib/media.js
!src/app/sitemap.xml/chunked-helpers.js

# allow case landing pages
!src/
!src/app/
!src/app/kin-insurance-privacy-torts/
!src/app/kin-insurance-privacy-torts/**
!src/app/vuori-privacy-torts/
!src/app/vuori-privacy-torts/**
!src/app/tower-hill-insurance-privacy-torts/
!src/app/tower-hill-insurance-privacy-torts/**
!src/app/slide-insurance-privacy-torts/
!src/app/slide-insurance-privacy-torts/**
!src/app/american-integrity-insurance-privacy-torts/
!src/app/american-integrity-insurance-privacy-torts/**
!src/app/privacy-torts/
!src/app/privacy-torts/**
!src/app/abogado-discapacidad-florida/
!src/app/abogado-discapacidad-florida/**
!src/app/abogados-florida/
!src/app/abogados-florida/**
!src/app/faq/
!src/app/faq/**

# allow layout/globals/components perf fixes
!src/app/layout.js
!src/app/globals.css
!src/app/components/
!src/app/components/Navbar/
!src/app/components/Navbar/Navbar.js

# allow property damage qualify flow
!src/app/property-damage-claims/
!src/app/property-damage-claims/**

# allow qualify-intake API route
!src/app/api/
!src/app/api/qualify-intake/
!src/app/api/qualify-intake/**

# allow package.json for nodemailer
!package.json
!package-lock.json
